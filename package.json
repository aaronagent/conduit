{
  "name": "conduit",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Copilot API reverse proxy with native Anthropic Messages API passthrough",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:proxy": "bun run --filter @conduit/proxy dev",
    "dev:dashboard": "bun run --filter dashboard dev",
    "lint": "eslint packages/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "^6.0.2"
  }
}
